# ========================================
# 数据库配置
# ========================================
DATABASE_URL=sqlite:///./waterms.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/waterms/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ========================================
# 业务配置
# ========================================
DEFAULT_CREDIT_BALANCE=0.0
PROMOTION_DEFAULT_TRIGGER_QTY=10
PROMOTION_DEFAULT_GIFT_QTY=1