# ========================================
# 密码策略
# ========================================
MIN_PASSWORD_LENGTH=12
REQUIRE_SPECIAL_CHAR=true
REQUIRE_NUMBER=true

# 默认管理员配置（⚠️ 首次登录后必须修改！）
DEFAULT_ADMIN_USERNAME=admin
