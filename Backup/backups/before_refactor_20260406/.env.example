# ========================================
# 企业服务管理平台 - 环境配置模板
# ========================================
# 
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改所有标记为 ⚠️ 的配置项
# 3. 确保 .env 文件不被提交到版本控制
# 
# ========================================

# 应用配置
ENVIRONMENT=production
DEBUG=false

# ========================================
# 安全配置（⚠️ 必须生成新的密钥！）
# ========================================
# 生成命令: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here-change-me
JWT_SECRET_KEY=your-jwt-secret-key-here-change-me

# JWT配置
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# ========================================
# 密码策略
# ========================================
MIN_PASSWORD_LENGTH=12
REQUIRE_SPECIAL_CHAR=true
REQUIRE_NUMBER=true

# 默认管理员配置（⚠️ 必须修改！）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-password

# ========================================
# 数据库配置
# ========================================
DATABASE_URL=sqlite:///./waterms.db
# 对于 PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# 会议室数据库（可选）
# MEETING_DATABASE_URL=sqlite:///../../Service_MeetingRoom/backend/meeting.db

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/waterms/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ========================================
# 业务配置
# ========================================
DEFAULT_CREDIT_BALANCE=0.0
PROMOTION_DEFAULT_TRIGGER_QTY=10
PROMOTION_DEFAULT_GIFT_QTY=1