@app.post("/api/reservation/create")
def create_reservation(
    request: ReservationPickupRequest,
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
):
    """
    创建预定订单（先付后用模式）
    用户支付预定后，可以分次领取
    """
    if not current_user:
        raise HTTPException(status_code=401, detail="未登录")

    # 验证产品是否存在
    product = db.query(Product).filter(Product.id == request.product_id).first()
    if not product:
        raise HTTPException(status_code=404, detail="产品不存在")

    if not product.is_active:
        raise HTTPException(status_code=400, detail="产品已停用")

    if product.stock < request.pickup_qty:
        raise HTTPException(status_code=400, detail="库存不足")

    # 计算优惠价格
    actual_price, note = calculate_promotion_price(
        db, current_user.id, request.product_id, request.pickup_qty, mode="prepay"
    )

    # 冻结库存
    product.stock -= request.pickup_qty

    # 创建预定交易记录
    reservation = Transaction(
        user_id=current_user.id,
        product_id=request.product_id,
        quantity=request.pickup_qty,
        reserved_qty=request.pickup_qty,
        used_qty=0,
        actual_price=actual_price,
        type="reservation",
        mode="prepay",
        payment_status="paid",  # 预定时即支付
        status="reserved",
        note=f"预定订单：{note}",
    )

    db.add(reservation)
    db.commit()
    db.refresh(reservation)

    return {
        "id": reservation.id,
        "user_id": current_user.id,
        "product_id": request.product_id,
        "product_name": product.name,
        "quantity": request.pickup_qty,
        "actual_price": actual_price,
        "payment_status": "paid",
        "note": note,
    }


