# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 应用配置
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./waterms.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# 安全配置（生产环境必须设置！）
SECRET_KEY=your-secret-key-change-in-production-2026

# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRE_HOURS=2

# 日志配置
LOG_LEVEL=INFO

# 会议室数据库（可选）
# MEETING_DATABASE_URL=sqlite:///../../Service_MeetingRoom/backend/meeting.db