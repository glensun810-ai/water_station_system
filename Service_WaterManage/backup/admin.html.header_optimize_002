                                <div v-if="record.applied_count > 0" class="space-y-1 max-h-24 overflow-y-auto">
                                    <div v-for="p in record.pickups.filter(x => x.settlement_status === 'applied')" :key="p.id" class="bg-blue-50 rounded p-1.5 text-xs flex justify-between items-center">
                                        <div>
                                            <span class="text-slate-700">{{ p.product_name }} × {{ p.quantity }}</span>
                                            <span class="text-slate-400 ml-1">{{ new Date(p.pickup_time).toLocaleDateString('zh-CN') }}</span>
                                        </div>
                                        <span class="font-medium text-blue-700">¥{{ (p.total_amount || 0).toFixed(2) }}</span>
                                    </div>
                                </div>
                            </template>
                            <template v-else-if="settlementTab === 'confirmed'">
                                <div v-if="record.confirmed_count > 0" class="space-y-1 max-h-24 overflow-y-auto">
                                    <div v-for="p in record.pickups.filter(x => x.settlement_status === 'settled')" :key="p.id" class="bg-green-50 rounded p-1.5 text-xs flex justify-between items-center">
                                        <div>
                                            <span class="text-slate-700">{{ p.product_name }} × {{ p.quantity }}</span>
                                            <span class="text-slate-400 ml-1">{{ new Date(p.pickup_time).toLocaleDateString('zh-CN') }}</span>
                                        </div>
                                        <span class="font-medium text-green-700">¥{{ (p.total_amount || 0).toFixed(2) }}</span>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <div v-if="!filteredOfficeSettlements || filteredOfficeSettlements.length === 0" class="text-center py-12 text-slate-400">
                        <svg class="w-16 h-16 mx-auto mb-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                        <p>暂无结算记录</p>
                    </div>
                </div>
            </div>
    </div>
    <!-- 关闭主内容区 v-if -->
</div>
<!-- 关闭 #app -->

<script>
        console.log('=== Admin.html Script Started ===');
        console.log('Vue available:', typeof Vue !== 'undefined');
        
        const { createApp, ref, computed, onMounted, watch } = Vue;
        console.log('Vue APIs extracted:', { createApp: !!createApp, ref: !!ref, computed: !!computed, onMounted: !!onMounted });

        createApp({
            setup() {
                console.log('=== Vue App Setup Started ===');
                // 允许通过 localStorage 配置 API 地址
                const API_BASE = localStorage.getItem('API_BASE') || 'https://jhw-ai.com/api';
                const API_AVAILABLE = ref(true);
                const apiError = ref(null);

                // 用户认证状态
                const user = ref(null);
                const token = ref(null);
                const isLoading = ref(true);
                const authError = ref(null);
                console.log('Initial state:', { isLoading: isLoading.value, authError: authError.value });

                // ========== 新增：导航增强状态 ==========
                const sidebarMobileOpen = ref(false); // 移动端侧边栏开关
                const showBackToTop = ref(false); // 是否显示返回顶部
                const activeTab = ref(localStorage.getItem('activeTab') || 'dashboard'); // 当前选中的标签页
                watch(activeTab, (newVal) => {
                    localStorage.setItem('activeTab', newVal);
                });

                // ========== 回收站相关状态 ==========
                const trashList = ref([]); // 回收站列表
                const selectedTrash = ref([]); // 已选择的回收站记录
                const selectedOffices = ref([]); // 已选择的办公室
                const allOfficesSelected = computed(() => filteredOffices.value.length > 0 && selectedOffices.value.length === filteredOffices.value.length);
                const selectAllTrash = ref(false); // 全选状态
                
                // ========== 领水记录相关状态 ==========
                const officePickups = ref([]); // 领水记录列表
                const selectedPickups = ref([]); // 选中的领水记录
                const officePickupFilter = ref({ officeId: '', status: '', dateFrom: '', dateTo: '', productId: '', searchPerson: '', quickDate: '' }); // 筛选状态
                
                const filteredPickups = computed(() => {
                    let result = officePickups.value || [];
                    const f = officePickupFilter.value;
                    if (f.status) {
                        result = result.filter(p => p.settlement_status === f.status);
                    }
                    if (f.officeId) {
                        result = result.filter(p => p.office_id === parseInt(f.officeId));
                    }
                    if (f.productId) {
                        result = result.filter(p => p.product_id === parseInt(f.productId));
                    }
                    if (f.dateFrom) {
                        const from = new Date(f.dateFrom);
                        result = result.filter(p => new Date(p.pickup_time) >= from);
                    }
                    if (f.dateTo) {
                        const to = new Date(f.dateTo);
                        to.setHours(23, 59, 59);
                        result = result.filter(p => new Date(p.pickup_time) <= to);
                    }
                    if (f.searchPerson) {
                        const kw = f.searchPerson.toLowerCase();
                        result = result.filter(p => p.pickup_person && p.pickup_person.toLowerCase().includes(kw));
                    }
                    return result;
                });
                
                const allPickupsSelected = computed(() => {
                    const pending = filteredPickups.value.filter(p => p.settlement_status !== 'settled');
                    return pending.length > 0 && selectedPickups.value.length === pending.length;
                });
                
                const selectedPendingAmount = computed(() => {
                    return selectedPickups.value.reduce((sum, id) => {
                        const p = officePickups.value.find(x => x.id === id);
                        return sum + (p && p.settlement_status === 'pending' ? p.total_amount : 0);
                    }, 0);
                });
                
                const selectedAppliedAmount = computed(() => {
                    return selectedPickups.value.reduce((sum, id) => {
                        const p = officePickups.value.find(x => x.id === id);
                        return sum + (p && p.settlement_status === 'applied' ? p.total_amount : 0);
                    }, 0);
                });
                
                const selectedPendingCount = computed(() => {
                    return selectedPickups.value.filter(id => {
                        const p = officePickups.value.find(x => x.id === id);
                        return p && p.settlement_status === 'pending';
                    }).length;
                });
                
                const selectedAppliedCount = computed(() => {
                    return selectedPickups.value.filter(id => {
                        const p = officePickups.value.find(x => x.id === id);
                        return p && p.settlement_status === 'applied';
                    }).length;
                });
                
                const pickupStats = computed(() => {
                    const pickups = officePickups.value || [];
                    const pending = pickups.filter(p => p.settlement_status === 'pending');
                    const applied = pickups.filter(p => p.settlement_status === 'applied');
                    const settled = pickups.filter(p => p.settlement_status === 'settled');
                    return {
                        total: { count: pickups.length, amount: pickups.reduce((s, p) => s + (p.total_amount || 0), 0) },
                        pending: { count: pending.length, amount: pending.reduce((s, p) => s + (p.total_amount || 0), 0) },
                        applied: { count: applied.length, amount: applied.reduce((s, p) => s + (p.total_amount || 0), 0) },
                        settled: { count: settled.length, amount: settled.reduce((s, p) => s + (p.total_amount || 0), 0) }
                    };
                });
                
                // ========== 结算记录相关状态 ==========
                // const settlementTab = ref('overview'); // 已移除，现在只有一个页面
                
                // 结算统计数据
                const settlementStats = ref({
                    pendingCount: 0,
                    pendingAmount: 0,
                    appliedCount: 0,
                    appliedAmount: 0,
                    confirmedCount: 0,
                    confirmedAmount: 0,
                    monthlyCount: 0,
                    monthlyAmount: 0,
                    weeklyCount: 0,
                    weeklyAmount: 0,
                    totalCount: 0,
                    totalAmount: 0,
                    overdueCount: 0,
                    overdueAmount: 0,
                    overdue15Count: 0,
                    overdue15Amount: 0,
                    overdue60Count: 0,
                    overdue60Amount: 0
                });
                
                // 结算申请列表
                const settlementApplications = ref([]);
                const settlementAppFilter = ref('all');
                const settlementSearch = ref('');
                const selectedSettlementApps = ref([]);
                const expandedSettlementAppId = ref(null);
                
                // 结算记录
                const settlementRecords = ref([]);
                const settlementTab = ref('applied'); // applied-待确认, pending-待付款, confirmed-已结清
                const settlementRecordFilter = ref('all');
                const settlementDateFrom = ref('');
                const settlementDateTo = ref('');
                const settlementQuickDate = ref('');
                
                // 计算当前Tab的统计信息
                const currentTabStats = computed(() => {
                    const offices = officeSettlements.value || [];
                    let officeCount = 0;
                    let recordCount = 0;
                    let totalAmount = 0;
                    
                    if (settlementTab.value === 'applied') {
                        // 付款待确认
                        const filtered = offices.filter(o => o.applied_count > 0);
                        officeCount = filtered.length;
                        recordCount = filtered.reduce((s, o) => s + (o.applied_count || 0), 0);
                        totalAmount = filtered.reduce((s, o) => s + (o.applied_amount || 0), 0);
                    } else if (settlementTab.value === 'pending') {
                        // 待付款
                        const filtered = offices.filter(o => o.pending_count > 0);
                        officeCount = filtered.length;
                        recordCount = filtered.reduce((s, o) => s + (o.pending_count || 0), 0);
                        totalAmount = filtered.reduce((s, o) => s + (o.pending_amount || 0), 0);
                    } else if (settlementTab.value === 'confirmed') {
                        // 已结清
                        const filtered = offices.filter(o => o.confirmed_count > 0);
                        officeCount = filtered.length;
                        recordCount = filtered.reduce((s, o) => s + (o.confirmed_count || 0), 0);
                        totalAmount = filtered.reduce((s, o) => s + (o.confirmed_amount || 0), 0);
                    }
                    
                    return { officeCount, recordCount, totalAmount };
                });

                // 各Tab的独立统计（不依赖当前选中的Tab）
                const appliedTabCount = computed(() => {
                    return (officeSettlements.value || []).filter(o => o.applied_count > 0).length;
                });
                const pendingTabCount = computed(() => {
                    return (officeSettlements.value || []).filter(o => o.pending_count > 0).length;
                });
                const confirmedTabCount = computed(() => {
                    return (officeSettlements.value || []).filter(o => o.confirmed_count > 0).length;
                });
                
                // 计算属性
                const filteredSettlementApps = computed(() => {
                    let result = settlementApplications.value || [];
                    if (settlementAppFilter.value !== 'all') {
                        result = result.filter(a => a.status === settlementAppFilter.value);
                    }
                    if (settlementSearch.value) {
                        const q = settlementSearch.value.toLowerCase();
                        result = result.filter(a => 
                            (a.user_name && a.user_name.toLowerCase().includes(q)) ||
                            (a.applied_by && a.applied_by.toLowerCase().includes(q)) ||
                            (a.office_name && a.office_name.toLowerCase().includes(q))
                        );
                    }
                    return result;
                });
                
                const filteredSettlementRecords = computed(() => {
                    let result = settlementRecords.value || [];
                    
                    // 按状态筛选（包括逾期）
                    if (settlementRecordFilter.value !== 'all') {
                        if (settlementRecordFilter.value === 'overdue') {
                            // 逾期：超过30天未结清
                            const now = new Date();
                            const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
                            result = result.filter(r => {
                                if (r.status === 'confirmed') return false;
                                const appliedDate = r.applied_at ? new Date(r.applied_at) : (r.created_at ? new Date(r.created_at) : null);
                                if (!appliedDate) return false;
                                return appliedDate <= thirtyDaysAgo;
                            });
                        } else {
                            result = result.filter(r => r.status === settlementRecordFilter.value);
                        }
                    }
                    
                    // 按办公室名称搜索
                    if (settlementSearch.value) {
                        const q = settlementSearch.value.toLowerCase();
                        result = result.filter(r => 
                            r.office_name && r.office_name.toLowerCase().includes(q)
                        );
                    }
                    
                    // 按日期筛选
                    if (settlementDateFrom.value) {
                        const from = new Date(settlementDateFrom.value);
                        result = result.filter(r => {
                            const date = r.applied_at ? new Date(r.applied_at) : (r.created_at ? new Date(r.created_at) : null);
                            return date && date >= from;
                        });
                    }
                    if (settlementDateTo.value) {
                        const to = new Date(settlementDateTo.value);
                        to.setHours(23, 59, 59);
                        result = result.filter(r => {
                            const date = r.applied_at ? new Date(r.applied_at) : (r.created_at ? new Date(r.created_at) : null);
                            return date && date <= to;
                        });
                    }
                    
                    return result;
                });
                
                // 筛选后的办公室结算申请（根据Tab筛选）
                const filteredOfficeSettlements = computed(() => {
                    if (!officeSettlements.value || !Array.isArray(officeSettlements.value)) {
                        return [];
                    }
                    let result = officeSettlements.value;
                    
                    // 根据Tab筛选
                    if (settlementTab.value === 'applied') {
                        // 付款待确认：显示有applied记录的办公室
                        result = result.filter(s => s.applied_count > 0);
                    } else if (settlementTab.value === 'pending') {
                        // 待付款：显示有pending记录的办公室
                        result = result.filter(s => s.pending_count > 0);
                    } else if (settlementTab.value === 'confirmed') {
                        // 已结清：显示有confirmed记录的办公室
                        result = result.filter(s => s.confirmed_count > 0);
                    }
                    
                    // 按状态筛选（additional filter）
                    if (settlementRecordFilter.value && settlementRecordFilter.value !== 'all') {
                        if (settlementRecordFilter.value === 'overdue') {
                            // 逾期：状态不是confirmed且超过30天
                            result = result.filter(s => s.status !== 'confirmed' && s.is_overdue);
                        } else if (settlementRecordFilter.value === 'overdue15') {
                            // 逾期15天以上
                            result = result.filter(s => s.status !== 'confirmed' && s.overdue_days >= 15);
                        } else if (settlementRecordFilter.value === 'overdue60') {
                            // 逾期60天以上
                            result = result.filter(s => s.status !== 'confirmed' && s.overdue_days >= 60);
                        } else if (settlementRecordFilter.value === 'unsettled') {
                            // 待结算（待付款+待确认）
                            result = result.filter(s => s.pending_count > 0 || s.applied_count > 0);
                        } else {
                            result = result.filter(s => s.status === settlementRecordFilter.value);
                        }
                    }
                    // 按办公室名称搜索
                    if (settlementSearch.value) {
                        const q = settlementSearch.value.toLowerCase();
                        result = result.filter(s => 
                            s.office_name && s.office_name.toLowerCase().includes(q)
                        );
                    }
                    // 按日期筛选
                    if (settlementDateFrom.value) {
                        const from = new Date(settlementDateFrom.value);
                        result = result.filter(s => s.applied_at && new Date(s.applied_at) >= from);
                    }
                    if (settlementDateTo.value) {
                        const to = new Date(settlementDateTo.value);
                        to.setHours(23, 59, 59);
                        result = result.filter(s => s.applied_at && new Date(s.applied_at) <= to);
                    }
                    // 按未结清金额倒序排列（欠款最多的在前）
                    result = [...(result || [])].sort((a, b) => {
                        const aAmount = (a.pending_amount || 0) + (a.applied_amount || 0);
                        const bAmount = (b.pending_amount || 0) + (b.applied_amount || 0);
                        return bAmount - aAmount;
                    });
                    return result;
                });
                
                // 加载结算统计数据
                const loadSettlementStats = async () => {
                    try {
                        const token = localStorage.getItem('token');
                        const headers = {};
                        if (token) {
                            headers['Authorization'] = `Bearer ${token}`;
                        }
                        // 获取办公室结算
                        const officeRes = await fetch(`${API_BASE}/admin/office-settlements`, { headers });
                        if (!officeRes.ok) {
                            console.error('Failed to load office settlements:', officeRes.status);
                            return;
                        }
                        const offices = await officeRes.json();
                        
                        const now = new Date();
                        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                        const weekAgo = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000);
                        const monthAgo = new Date(now.getFullYear(), now.getMonth(), 1);
                        const fifteenDaysAgo = new Date(now.getTime() - 15 * 24 * 60 * 60 * 1000);
                        const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
                        const sixtyDaysAgo = new Date(now.getTime() - 60 * 24 * 60 * 60 * 1000);
                        
                        // 统计所有办公室的pending记录（待付款）
                        let totalPendingCount = 0;
                        let totalPendingAmount = 0;
                        // 统计所有办公室的applied记录（待确认）
                        let totalAppliedCount = 0;
                        let totalAppliedAmount = 0;
                        // 统计所有办公室的confirmed记录（已结清）
                        let totalConfirmedCount = 0;
                        let totalConfirmedAmount = 0;
                        
                        // 逾期统计
                        let overdue15Count = 0;
                        let overdue15Amount = 0;
                        let overdueCount = 0;
                        let overdueAmount = 0;
                        let overdue60Count = 0;
                        let overdue60Amount = 0;
                        
                        // 本月/本周结算
                        let monthlyCount = 0;
                        let monthlyAmount = 0;
                        let weeklyCount = 0;
                        let weeklyAmount = 0;
                        
                        // 遍历所有办公室，汇总统计
                        for (const office of offices) {
                            const pendingCnt = office.pending_count || 0;
                            const pendingAmt = office.pending_amount || 0;
                            const appliedCnt = office.applied_count || 0;
                            const appliedAmt = office.applied_amount || 0;
                            const confirmedCnt = office.confirmed_count || 0;
                            const confirmedAmt = office.confirmed_amount || 0;
                            
                            // 待付款统计
                            totalPendingCount += pendingCnt;
                            totalPendingAmount += pendingAmt;
                            
                            // 待确认统计
                            totalAppliedCount += appliedCnt;
                            totalAppliedAmount += appliedAmt;
                            
                            // 已结清统计
                            totalConfirmedCount += confirmedCnt;
                            totalConfirmedAmount += confirmedAmt;
                            
                            // 检查是否有过pending记录用于逾期判断
                            if (pendingCnt > 0 || appliedCnt > 0) {
                                const appliedDate = office.applied_at ? new Date(office.applied_at) : null;
                                if (appliedDate) {
                                    // 逾期15天
                                    if (appliedDate <= fifteenDaysAgo) {
                                        overdue15Count++;
                                        overdue15Amount += pendingAmt + appliedAmt;
                                    }
                                    // 逾期30天
                                    if (appliedDate <= thirtyDaysAgo) {
                                        overdueCount++;
                                        overdueAmount += pendingAmt + appliedAmt;
                                    }
                                    // 逾期60天
                                    if (appliedDate <= sixtyDaysAgo) {
                                        overdue60Count++;
                                        overdue60Amount += pendingAmt + appliedAmt;
                                    }
                                }
                            }
                            
                            // 本月结算
                            if (office.confirmed_at && new Date(office.confirmed_at) >= monthAgo) {
                                monthlyCount++;
                                monthlyAmount += confirmedAmt;
                            }
                            // 本周结算
                            if (office.confirmed_at && new Date(office.confirmed_at) >= weekAgo) {
                                weeklyCount++;
                                weeklyAmount += confirmedAmt;
                            }
                        }
                        
                        // 计算逾期15天和逾期30天的差集（15-30天之间的）
                        overdue15Count = overdue15Count - overdueCount;
                        overdue15Amount = overdue15Amount - overdueAmount;
                        
                        // 计算逾期30天和逾期60天的差集
                        const overdue30to60Count = overdueCount - overdue60Count;
                        const overdue30to60Amount = overdueAmount - overdue60Amount;
                        
                        settlementStats.value = {
                            // 待付款
                            pendingCount: totalPendingCount,
                            pendingAmount: totalPendingAmount,
                            // 待确认
                            appliedCount: totalAppliedCount,
                            appliedAmount: totalAppliedAmount,
                            // 已结清
                            confirmedCount: totalConfirmedCount,
                            confirmedAmount: totalConfirmedAmount,
                            // 本月已结算
                            monthlyCount: monthlyCount,
                            monthlyAmount: monthlyAmount,
                            // 本周结算
                            weeklyCount: weeklyCount,
                            weeklyAmount: weeklyAmount,
                            // 累计
                            totalCount: offices.length,
                            totalAmount: totalPendingAmount + totalAppliedAmount + totalConfirmedAmount,
                            // 逾期15天（15-30天之间）
                            overdue15Count: Math.max(0, overdue15Count),
                            overdue15Amount: Math.max(0, overdue15Amount),
                            // 逾期30天
                            overdueCount: overdueCount,
                            overdueAmount: overdueAmount,
                            // 逾期60天
                            overdue60Count: overdue60Count,
                            overdue60Amount: overdue60Amount
                        };
                        
                        // 获取个人结算申请
                        const appRes = await fetch(`${API_BASE}/admin/settlement-applications`);
                        if (appRes.ok) {
                            const apps = await appRes.json();
                            // 合并到统计
                            const pendingApps = apps.filter(a => a.status === 'applied');
                            settlementStats.value.pendingCount += pendingApps.length;
                            settlementStats.value.pendingAmount += pendingApps.reduce((s, a) => s + (a.total_amount || 0), 0);
                            
                            // 逾期统计：从个人结算申请中计算
                            const now = new Date();
                            const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
                            const overdueApps = apps.filter(a => {
                                if (a.status === 'confirmed') return false;
                                const appliedDate = a.created_at ? new Date(a.created_at) : null;
                                if (!appliedDate) return false;
                                return appliedDate <= thirtyDaysAgo;
                            });
                            settlementStats.value.overdueCount += overdueApps.length;
                            settlementStats.value.overdueAmount += overdueApps.reduce((s, a) => s + (a.total_amount || 0), 0);
                        }
                    } catch (e) {
                        console.error('加载结算统计失败:', e);
                    }
                };
                
                // 加载结算申请列表
                const loadSettlementApplications = async () => {
                    try {
                        const token = localStorage.getItem('token');
                        const headers = {};
                        if (token) {
                            headers['Authorization'] = `Bearer ${token}`;
                        }
                        const res = await fetch(`${API_BASE}/admin/settlement-applications`, { headers });
                        if (res.ok) {
                            settlementApplications.value = await res.json();
                        } else {
                            console.error('Failed to load settlement applications:', res.status);
                            settlementApplications.value = [];
                        }
                    } catch (e) {
                        console.error('加载结算申请失败:', e);
                        settlementApplications.value = [];
                    }
                };
                
                // 批量确认办公室结算
                const batchConfirmOfficeSettlements = async () => {
                    if (!confirm(`确认已收到选中的 ${selectedSettlementApps.value.length} 笔结算款项？`)) return;
                    
                    try {
                        const token = localStorage.getItem('token');
                        const headers = { 'Content-Type': 'application/json' };
                        if (token) headers['Authorization'] = `Bearer ${token}`;
                        
                        // 获取所有选中的结算记录
                        const res = await fetch(`${API_BASE}/admin/office-settlements`, { headers });
                        const allSettlements = await res.json();
                        
                        // 收集所有pending和applied的pickup id
                        let allPickupIds = [];
                        for (const officeId of selectedSettlementApps.value) {
                            const settlement = allSettlements.find(s => s.id === officeId);
                            if (!settlement) continue;
                            
                            const pickupIds = settlement.pickups
                                .filter(p => p.settlement_status === 'pending' || p.settlement_status === 'applied')
                                .map(p => p.id);
                            
